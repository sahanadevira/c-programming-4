#include<stdio.h>
int main()
{
    int hours, minutes, seconds;
    printf("enter time in hours:");
    scanf("%d", &hours);
    minutes = hours * 60;
    seconds = hours * 3600;
    printf("%d hours = %d minutes\n", hours, minutes);
    printf("%d hours = %d seconds\n", hours, seconds);
    return 0;
}
